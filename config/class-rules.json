{
  "path_rules": [
    {
      "contains": "polar",
      "class": "Polarization"
    },
    {
      "contains": "tcc",
      "class": "Tcc"
    },
    {
      "contains": "omega",
      "class": "Omega"
    },
    {
      "contains": "x3872",
      "class": "X3872"
    },
    {
      "contains": "baryon",
      "class": "Baryons"
    }
  ],
  "stem_rules": [
    {
      "regex": "^(meson|baryon|neutron|proton)",
      "class": "Particle Cartoons"
    },
    {
      "regex": "(decay|collision)",
      "class": "Decay and Collision"
    }
  ],
  "generic_folder_names": [
    "inline-figs",
    "in-line-figures",
    "tikz",
    "tikz-figs",
    "figs",
    "figures",
    "images",
    "paper",
    "slides",
    "main",
    "backup",
    "review",
    "examples"
  ]
}
